    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## Libraries Import"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "import pandas as pd\n",
        "import numpy as np\n",
        "import json\n",
        "import io\n",
        "import os\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "from rapidfuzz import fuzz, process\n",
        "from azure.storage.blob import BlobServiceClient\n",
        "from snowflake.sqlalchemy import URL\n",
        "from sqlalchemy import create_engine, text\n",
        "\n",
        "print('All libraries imported successfully!')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## Connection String Load"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "with open('config.json') as f:\n",
        "    config = json.load(f)\n",
        "\n",
        "# Azure\n",
        "blob_service_client = BlobServiceClient.from_connection_string(config['AZURE_CONNECTION_STRING'])\n",
        "print('Azure connected successfully')\n",
        "\n",
        "# Snowflake\n",
        "engine = create_engine(URL(\n",
        "    user=config['SNOWFLAKE_USER'],\n",
        "    password=config['SNOWFLAKE_PASSWORD'],\n",
        "    account=config['SNOWFLAKE_ACCOUNT'],\n",
        "    warehouse=config['SNOWFLAKE_WAREHOUSE'],\n",
        "    database=config['SNOWFLAKE_DATABASE'],\n",
        "    schema=config['SNOWFLAKE_SCHEMA']\n",
        "))\n",
        "print('Snowflake connected successfully')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## Extraction"]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["### Extraction - RateMD Doctors Data"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Load from local parquet (already downloaded from Azure previously)\n",
        "# Set SKIP_AZURE = False to re-download from Azure\n",
        "LOCAL_FILE = 'doctors_flat.parquet'\n",
        "SKIP_AZURE = True\n",
        "\n",
        "if not SKIP_AZURE or not os.path.exists(LOCAL_FILE):\n",
        "    print('Downloading from Azure...')\n",
        "    RATEMD_CONTAINER = 'ratemdreviews'\n",
        "    blob_client = blob_service_client.get_blob_client(\n",
        "        container=RATEMD_CONTAINER, blob='doctors_flat.json'\n",
        "    )\n",
        "    buffer = io.BytesIO()\n",
        "    properties = blob_client.get_blob_properties()\n",
        "    size_mb = properties.size / 1024 / 1024\n",
        "    downloaded = 0\n",
        "    for chunk in blob_client.download_blob().chunks():\n",
        "        buffer.write(chunk)\n",
        "        downloaded += len(chunk)\n",
        "        print(f'Downloaded {downloaded/1024/1024:.1f} / {size_mb:.1f} MB', end='\\r')\n",
        "    print('\\nDownload complete!')\n",
        "    buffer.seek(0)\n",
        "    doctors_raw = pd.read_json(buffer)\n",
        "    doctors_raw.to_parquet(LOCAL_FILE, index=False)\n",
        "    print('Saved locally as doctors_flat.parquet')\n",
        "else:\n",
        "    print('Loading from local parquet file...')\n",
        "    doctors_raw = pd.read_parquet(LOCAL_FILE)\n",
        "    print('Done!')\n",
        "\n",
        "print('Shape:', doctors_raw.shape)\n",
        "print('Columns:', doctors_raw.columns.tolist())\n",
        "doctors_raw.head(3)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## Transformation"]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["### Data Profiling"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "print('=== RATEMD RAW ===')\n",
        "print('Shape:', doctors_raw.shape)\n",
        "print()\n",
        "print('Dtypes:')\n",
        "print(doctors_raw.dtypes)\n",
        "print()\n",
        "print('Null counts:')\n",
        "print(doctors_raw.isnull().sum())\n",
        "print()\n",
        "print('Country distribution:')\n",
        "print(doctors_raw['country'].value_counts().head(10))\n",
        "print()\n",
        "print('Specialty distribution (top 10):')\n",
        "print(doctors_raw['specialty_name'].value_counts().head(10))\n",
        "print()\n",
        "print('Rating average distribution:')\n",
        "print(doctors_raw['rating_average'].describe())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["### Data Cleaning"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 1: Filter to US only\n",
        "print('Before US filter:', len(doctors_raw))\n",
        "df = doctors_raw[doctors_raw['country'] == 'United States'].copy()\n",
        "print('After US filter:', len(df))\n",
        "\n",
        "# Step 2: Keep only needed columns\n",
        "cols_needed = [\n",
        "    'doctor_id', 'full_name', 'specialty', 'specialty_name',\n",
        "    'accepting_patients', 'location_category', 'address',\n",
        "    'postal_code', 'city', 'province', 'country',\n",
        "    'rating_average', 'rating_staff', 'rating_punctuality',\n",
        "    'rating_helpfulness', 'rating_knowledge', 'rating_count',\n",
        "    'verified'\n",
        "]\n",
        "df = df[cols_needed]\n",
        "print('After column selection:', df.shape)\n",
        "\n",
        "# Step 3: Drop rows with no name\n",
        "df = df.dropna(subset=['full_name'])\n",
        "print('After dropping null names:', len(df))\n",
        "\n",
        "# Step 4: Drop rows with no postal code\n",
        "df = df.dropna(subset=['postal_code'])\n",
        "print('After dropping null postal codes:', len(df))\n",
        "\n",
        "# Step 5: Standardize doctor names\n",
        "df['full_name_clean'] = df['full_name'].str.strip().str.title()\n",
        "\n",
        "# Step 6: Standardize postal code to 5 digits\n",
        "df['postal_code'] = df['postal_code'].astype(str).str.strip().str[:5].str.zfill(5)\n",
        "\n",
        "print()\n",
        "print('Final cleaned shape:', df.shape)\n",
        "df[['full_name_clean', 'specialty', 'postal_code', 'rating_average', 'rating_count']].head(5)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Step 7: Fuzzy matching deduplication\n",
        "print('Running fuzzy matching deduplication...')\n",
        "from rapidfuzz import fuzz, process\n",
        "\n",
        "def get_canonical_name(name, name_list, threshold=90):\n",
        "    if not name_list:\n",
        "        return name\n",
        "    best_match = process.extractOne(name, name_list, scorer=fuzz.token_sort_ratio)\n",
        "    if best_match and best_match[1] >= threshold:\n",
        "        return best_match[0]\n",
        "    return name\n",
        "\n",
        "canonical_map = {}\n",
        "groups = df.groupby(['postal_code', 'specialty'])['full_name_clean'].apply(list)\n",
        "total = len(groups)\n",
        "\n",
        "for idx, ((zip_code, specialty), names) in enumerate(groups.items()):\n",
        "    if idx % 10000 == 0:\n",
        "        print(f'Progress: {idx}/{total} groups processed', end='\\r')\n",
        "    unique_names = list(set(names))\n",
        "    if len(unique_names) == 1:\n",
        "        for name in names:\n",
        "            canonical_map[(zip_code, specialty, name)] = unique_names[0]\n",
        "        continue\n",
        "    canonical_names = []\n",
        "    for name in unique_names:\n",
        "        canonical = get_canonical_name(name, canonical_names)\n",
        "        if canonical == name:\n",
        "            canonical_names.append(name)\n",
        "        canonical_map[(zip_code, specialty, name)] = canonical\n",
        "\n",
        "df['canonical_name'] = df.apply(\n",
        "    lambda row: canonical_map.get(\n",
        "        (row['postal_code'], row['specialty'], row['full_name_clean']),\n",
        "        row['full_name_clean']\n",
        "    ), axis=1\n",
        ")\n",
        "\n",
        "print('\\nFuzzy matching complete')\n",
        "before = df['full_name_clean'].nunique()\n",
        "after = df['canonical_name'].nunique()\n",
        "print(f'Unique names before: {before}')\n",
        "print(f'Unique names after:  {after}')\n",
        "print(f'Duplicates merged:   {before - after}')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["### Data Reformatting"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Reformat rating columns to float\n",
        "rating_cols = ['rating_average', 'rating_staff', 'rating_punctuality',\n",
        "               'rating_helpfulness', 'rating_knowledge']\n",
        "for col in rating_cols:\n",
        "    df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0)\n",
        "\n",
        "# Reformat rating_count to integer\n",
        "df['rating_count'] = pd.to_numeric(df['rating_count'], errors='coerce').fillna(0).astype(int)\n",
        "\n",
        "# Reformat accepting_patients to boolean\n",
        "df['accepting_patients'] = df['accepting_patients'].fillna(0).astype(bool)\n",
        "\n",
        "print('Reformatting complete')\n",
        "print(df[['rating_average', 'rating_count', 'accepting_patients']].dtypes)"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["### Data Transformation - Build Dimension Tables"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Build dim_specialty\n",
        "specialties = df[['specialty', 'specialty_name']].drop_duplicates().dropna().reset_index(drop=True)\n",
        "\n",
        "dim_specialty = pd.DataFrame({\n",
        "    'specialty_id':   range(1, len(specialties) + 1),\n",
        "    'specialty_name': specialties['specialty_name']\n",
        "})\n",
        "\n",
        "print('dim_specialty shape:', dim_specialty.shape)\n",
        "dim_specialty.head(10)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Build dim_doctor\n",
        "# columns: doctor_id, canonical_name, specialty_id, accepting_patients, location_category, verified\n",
        "specialty_map = dict(zip(specialties['specialty_name'], dim_specialty['specialty_id']))\n",
        "\n",
        "doctor_agg = df.groupby('doctor_id').agg(\n",
        "    canonical_name=('canonical_name', 'first'),\n",
        "    specialty_name=('specialty_name', 'first'),\n",
        "    accepting_patients=('accepting_patients', 'first'),\n",
        "    location_category=('location_category', 'first'),\n",
        "    verified=('verified', 'first')\n",
        ").reset_index(drop=True)\n",
        "\n",
        "dim_doctor = pd.DataFrame({\n",
        "    'doctor_id':          range(1, len(doctor_agg) + 1),\n",
        "    'canonical_name':     doctor_agg['canonical_name'],\n",
        "    'specialty_id':       doctor_agg['specialty_name'].map(specialty_map),\n",
        "    'accepting_patients': doctor_agg['accepting_patients'],\n",
        "    'location_category':  doctor_agg['location_category'],\n",
        "    'verified':           doctor_agg['verified']\n",
        "})\n",
        "\n",
        "print('dim_doctor shape:', dim_doctor.shape)\n",
        "print('Null counts:')\n",
        "print(dim_doctor.isnull().sum())\n",
        "dim_doctor.head(5)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Build fact_doctor_rating\n",
        "# columns: fact_rating_id, doctor_id, geography_id, specialty_id,\n",
        "#          avg_rating, review_count, staff_rating, punctuality_rating,\n",
        "#          helpfulness_rating, knowledge_rating\n",
        "\n",
        "# Create lookup maps\n",
        "doctor_name_map = dict(zip(doctor_agg['canonical_name'], range(1, len(doctor_agg) + 1)))\n",
        "\n",
        "# Load geography for zip join\n",
        "dim_geo_lookup = pd.read_sql('SELECT geography_id, zip_code FROM dim_geography', engine)\n",
        "geo_map = dict(zip(dim_geo_lookup['zip_code'], dim_geo_lookup['geography_id']))\n",
        "\n",
        "fact_doctor_rating = pd.DataFrame({\n",
        "    'fact_rating_id':      range(1, len(df) + 1),\n",
        "    'doctor_id':           df['canonical_name'].map(doctor_name_map),\n",
        "    'geography_id':        df['postal_code'].map(geo_map),\n",
        "    'specialty_id':        df['specialty_name'].map(specialty_map),\n",
        "    'avg_rating':          df['rating_average'],\n",
        "    'review_count':        df['rating_count'],\n",
        "    'staff_rating':        df['rating_staff'],\n",
        "    'punctuality_rating':  df['rating_punctuality'],\n",
        "    'helpfulness_rating':  df['rating_helpfulness'],\n",
        "    'knowledge_rating':    df['rating_knowledge']\n",
        "})\n",
        "\n",
        "print('fact_doctor_rating shape:', fact_doctor_rating.shape)\n",
        "print('Null counts:')\n",
        "print(fact_doctor_rating.isnull().sum())\n",
        "fact_doctor_rating.head(5)"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Fix null geography_id by matching on city + state\n",
        "unmatched = df[~df['postal_code'].isin(dim_geo_lookup['zip_code'])].copy()\n",
        "print(f'Unmatched records: {len(unmatched)}')\n",
        "\n",
        "city_state_lookup = pd.read_sql(\"\"\"\n",
        "    SELECT geography_id, city, state_abbr FROM dim_geography\n",
        "\"\"\", engine)\n",
        "\n",
        "city_state_lookup['city_clean'] = city_state_lookup['city'].str.strip().str.title()\n",
        "unmatched['city_clean'] = unmatched['city'].str.strip().str.title()\n",
        "\n",
        "state_abbr_lookup = pd.read_sql('SELECT DISTINCT state, state_abbr FROM dim_geography', engine)\n",
        "state_abbr_map = dict(zip(state_abbr_lookup['state'], state_abbr_lookup['state_abbr']))\n",
        "\n",
        "city_map = city_state_lookup.groupby(['city_clean', 'state_abbr'])['geography_id'].first().reset_index()\n",
        "city_map_dict = dict(zip(zip(city_map['city_clean'], city_map['state_abbr']), city_map['geography_id']))\n",
        "\n",
        "unmatched['province_abbr'] = unmatched['province'].map(state_abbr_map)\n",
        "unmatched['geography_id_fix'] = unmatched.apply(\n",
        "    lambda row: city_map_dict.get((row['city_clean'], row['province_abbr'])), axis=1\n",
        ")\n",
        "\n",
        "fix_map = dict(zip(unmatched['postal_code'], unmatched['geography_id_fix']))\n",
        "null_mask = fact_doctor_rating['geography_id'].isna()\n",
        "fact_doctor_rating.loc[null_mask, 'geography_id'] = df.loc[null_mask, 'postal_code'].map(fix_map)\n",
        "\n",
        "remaining = fact_doctor_rating['geography_id'].isna().sum()\n",
        "print(f'Remaining null geography_id: {remaining:,} ({remaining/len(fact_doctor_rating)*100:.1f}%)')"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["### Data Consolidation"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "print('=== dim_specialty ===')\n",
        "print('Shape:', dim_specialty.shape)\n",
        "print(dim_specialty.head(3))\n",
        "print()\n",
        "print('=== dim_doctor ===')\n",
        "print('Shape:', dim_doctor.shape)\n",
        "print(dim_doctor.head(3))\n",
        "print()\n",
        "print('=== fact_doctor_rating ===')\n",
        "print('Shape:', fact_doctor_rating.shape)\n",
        "print(fact_doctor_rating.head(3))"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## Loading"]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Load dim_specialty\n",
        "with engine.connect() as conn:\n",
        "    conn.execute(text('DROP TABLE IF EXISTS dim_specialty'))\n",
        "    conn.execute(text(\"\"\"\n",
        "        CREATE TABLE dim_specialty (\n",
        "            specialty_id   INTEGER,\n",
        "            specialty_name VARCHAR(200)\n",
        "        )\n",
        "    \"\"\"))\n",
        "    conn.commit()\n",
        "\n",
        "dim_specialty.to_sql('dim_specialty', engine, if_exists='append', index=False, method='multi')\n",
        "print('dim_specialty loaded:', len(dim_specialty), 'rows')\n",
        "print(pd.read_sql('SELECT * FROM dim_specialty LIMIT 5', engine))"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Load dim_doctor\n",
        "with engine.connect() as conn:\n",
        "    conn.execute(text('DROP TABLE IF EXISTS dim_doctor'))\n",
        "    conn.execute(text(\"\"\"\n",
        "        CREATE TABLE dim_doctor (\n",
        "            doctor_id          INTEGER,\n",
        "            canonical_name     VARCHAR(300),\n",
        "            specialty_id       INTEGER,\n",
        "            accepting_patients BOOLEAN,\n",
        "            location_category  VARCHAR(100),\n",
        "            verified           BOOLEAN\n",
        "        )\n",
        "    \"\"\"))\n",
        "    conn.commit()\n",
        "print('dim_doctor table created')\n",
        "\n",
        "chunksize = 5000\n",
        "for i in range(0, dim_doctor.shape[0], chunksize):\n",
        "    chunk = dim_doctor[i:i + chunksize]\n",
        "    chunk.to_sql('dim_doctor', engine, if_exists='append', index=False, method='multi')\n",
        "    print(f'Loaded rows {i} to {i + len(chunk)}', end='\\r')\n",
        "\n",
        "print('\\ndim_doctor loaded successfully!')\n",
        "print('Total rows:', pd.read_sql('SELECT COUNT(*) AS total FROM dim_doctor', engine)['total'][0])"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Load fact_doctor_rating\n",
        "with engine.connect() as conn:\n",
        "    conn.execute(text('DROP TABLE IF EXISTS fact_doctor_rating'))\n",
        "    conn.execute(text(\"\"\"\n",
        "        CREATE TABLE fact_doctor_rating (\n",
        "            fact_rating_id     INTEGER,\n",
        "            doctor_id          INTEGER,\n",
        "            geography_id       INTEGER,\n",
        "            specialty_id       INTEGER,\n",
        "            avg_rating         FLOAT,\n",
        "            review_count       INTEGER,\n",
        "            staff_rating       FLOAT,\n",
        "            punctuality_rating FLOAT,\n",
        "            helpfulness_rating FLOAT,\n",
        "            knowledge_rating   FLOAT\n",
        "        )\n",
        "    \"\"\"))\n",
        "    conn.commit()\n",
        "print('fact_doctor_rating table created')\n",
        "\n",
        "chunksize = 5000\n",
        "for i in range(0, fact_doctor_rating.shape[0], chunksize):\n",
        "    chunk = fact_doctor_rating[i:i + chunksize]\n",
        "    chunk.to_sql('fact_doctor_rating', engine, if_exists='append', index=False, method='multi')\n",
        "    print(f'Loaded rows {i} to {i + len(chunk)}', end='\\r')\n",
        "\n",
        "print('\\nfact_doctor_rating loaded successfully!')\n",
        "print('Total rows:', pd.read_sql('SELECT COUNT(*) AS total FROM fact_doctor_rating', engine)['total'][0])"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "# Final verification\n",
        "print('=== Snowflake Table Summary ===')\n",
        "tables = ['dim_specialty', 'dim_doctor', 'dim_geography', 'fact_doctor_rating']\n",
        "for table in tables:\n",
        "    result = pd.read_sql(f'SELECT COUNT(*) AS total FROM {table}', engine)\n",
        "    print(f'{table}: {result[\"total\"][0]:,} rows')\n",
        "\n",
        "print()\n",
        "print('Sample fact_doctor_rating:')\n",
        "print(pd.read_sql('SELECT * FROM fact_doctor_rating LIMIT 5', engine))"
      ]
    }
